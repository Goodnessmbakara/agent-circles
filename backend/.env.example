SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
# Comma-separated list of known pool contract IDs (new ones added via POST /api/pools/register)
CONTRACT_IDS=
AGENT_SECRET_KEY=
# Chat LLM: use CLAUDE_API_KEY, or LLM_PROVIDER=bedrock + AWS_* + BEDROCK_MODEL_ID
CLAUDE_API_KEY=
LLM_PROVIDER=anthropic
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
PORT=3001
# Demo pool: either set a Setup pool C… ID, or auto-deploy with a funded testnet deployer key.
DEMO_CONTRACT_ID=
# Secret key (S…) — uploads WASM, creates contract, initializes; pool id saved to DEMO_AUTO_POOL_FILE.
DEMO_DEPLOYER_SECRET_KEY=
DEMO_AUTO_POOL_FILE=data/demo_autopool.json
# Set to 1 to ignore persisted file and deploy a new pool (needs DEMO_DEPLOYER_SECRET_KEY).
DEMO_FORCE_REDEPLOY=0
# Default: native XLM SAC (Friendbot covers contributions). Override with e.g. testnet USDC SAC.
# DEMO_AUTO_POOL_TOKEN=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
DEMO_AUTO_POOL_CONTRIBUTION=1000000
DEMO_AUTO_POOL_ROUND_PERIOD_SEC=5
DEMO_AUTO_POOL_MAX_MEMBERS=5
DEMO_AUTO_POOL_MANAGER_FEE_BPS=0
# Demo API rate limits (seconds). Use 0 to disable (default: off).
DEMO_SEED_COOLDOWN_SEC=0
DEMO_RUN_COOLDOWN_SEC=0
