# API image (Fastify). WASM is prebuilt and committed under artifacts/ (rebuild when contract changes).
# Deploy from repo root: fly deploy
# syntax=docker/dockerfile:1
FROM node:20-bookworm-slim AS node-build
WORKDIR /app
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable && corepack prepare pnpm@latest --activate
COPY backend/package.json backend/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
COPY backend/tsconfig.json ./
COPY backend/src ./src
RUN pnpm run build

FROM node:20-bookworm-slim AS runner
WORKDIR /app
ARG GIT_COMMIT=unknown
ENV GIT_COMMIT=${GIT_COMMIT}
ENV NODE_ENV=production
ENV ROSCA_POOL_WASM_PATH=/app/rosca_pool.wasm
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
RUN corepack enable && corepack prepare pnpm@latest --activate
COPY backend/package.json backend/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile --prod
COPY --from=node-build /app/dist ./dist
COPY artifacts/rosca_pool.wasm ./rosca_pool.wasm
RUN mkdir -p /app/data
EXPOSE 3001
CMD ["node", "dist/index.js"]
